    given-names: William
    affiliation: "DSIO, CHU de Guyane"
    email: william.meri@gmail.com
repository-code: "https://github.com/Tarzzan/PULSAR-CHU"
url: "https://github.com/Tarzzan/PULSAR-CHU"
license: Apache-2.0
version: "2.3.1"
date-released: "2026-06-11"
keywords:
  - "agent IA"
  - "santé"
  - "CHU"
  - "RGPD"
  - "ISO 27001"
  - "anonymisation PHI"
  - "souveraineté numérique"
references:
