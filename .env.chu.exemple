# =============================================================================
# HERMES CHU — Variables d'environnement
# =============================================================================
# Copiez ce fichier en .env.chu et renseignez vos valeurs.
# NE JAMAIS commiter .env.chu dans git (il est dans .gitignore).
# =============================================================================

# --- Identité du déploiement ---
CHU_NOM="CHU de [Votre Établissement]"
CHU_FINESS=""
CHU_ENVIRONNEMENT="developpement"   # developpement | recette | production

# --- Privacy Engine RGPD ---
CHU_PRIVACY_ENGINE_ACTIF="true"     # true = anonymisation active par défaut

# =============================================================================
# CHOISIR UN SEUL FOURNISSEUR LLM (commenter les autres)
# =============================================================================

# --- Option 1 : Azure OpenAI (recommandé pour le POC) ---
# Données anonymisées par le Privacy Engine avant envoi
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT="https://votre-ressource.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_API_VERSION="2024-02-01"

# --- Option 2 : OpenAI direct ---
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o"

# --- Option 3 : Ollama local (POC sans GPU dédié) ---
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="hermes3:70b"

# --- Option 4 : vLLM on-premise (production souveraine) ---
# VLLM_BASE_URL="http://vllm-service:8000/v1"
# VLLM_MODEL="NousResearch/Hermes-3-Llama-3.1-70B-Instruct"
# VLLM_API_KEY=""

# --- Option 5 : OpenRouter (accès à 200+ modèles) ---
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="nousresearch/hermes-3-llama-3.1-70b"

# =============================================================================
# INFRASTRUCTURE (optionnel pour le POC)
# =============================================================================

# --- Base de données (journal d'audit ISO 27001) ---
# DATABASE_URL="postgresql://hermes:password@localhost:5432/hermes_chu"

# --- Redis (table de correspondance PHI — Privacy Engine) ---
# REDIS_URL="redis://localhost:6379"

# --- Intégration SIH FHIR R4 (production uniquement) ---
# FHIR_BASE_URL=""
# FHIR_TOKEN_URL=""
# FHIR_CLIENT_ID=""
# FHIR_CLIENT_SECRET=""
